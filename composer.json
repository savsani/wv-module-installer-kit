{
    "name": "wv/module-installer-kit",
    "description": "Installs and updates Wv's reusable Laravel modules (Core, and future modules) as first-class, editable code inside an app's Modules/ directory.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "nwidart/laravel-modules": "^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Wv\\ModuleInstallerKit\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wv\\ModuleInstallerKit\\ModuleInstallerKitServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
